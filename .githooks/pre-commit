#!/bin/bash

## Check naming format of the H3 titles in BENCHMARKS.md
# Expected: ### <MODEL> - <QUANTIZATION> - <SIZE> (GPU) - <BENCH_URL>

# This regex ensures:
# 1. Starts with ###
# 2. Model name (can contain spaces)
# 3. Quantization (no spaces)
# 4. Size (no spaces)
# 5. GPU inside parentheses
# 6. Benchmark URL

INVALID_TITLES=$(perl -ne 'print if /^### / && !/^### (.*?) - (\S+?) - (\S+?) \((.*?)\) - (https?:\/\/\S+)$/' BENCHMARKS.md)

if [ -n "$INVALID_TITLES" ]; then
    echo "Error: The following H3 titles in BENCHMARKS.md do not follow the required format:"
    echo "$INVALID_TITLES"
    echo ""
    echo "Expected format:"
    echo "### <MODEL> - <QUANTIZATION> - <SIZE> (GPU) - <BENCH_URL>"
    echo "Example:"
    echo "### Phi 4 Mini Instruct 4.5B - Q4_K - Medium (NVIDIA GeForce GTX 1660 6GB) - https://www.localscore.ai/result/3908"
    exit 1
fi

echo "All H3 titles in BENCHMARKS.md follow the required format."
